# 多階段建置
FROM node:18-alpine as builder

WORKDIR /app

# 複製 package.json
COPY frontend/package*.json ./

# 安裝依賴
RUN npm install

# 複製源代碼
COPY frontend/ .

# 建置應用
RUN npm run build

# 生產階段
FROM nginx:alpine

# 複製建置結果到 nginx
COPY --from=builder /app/dist /usr/share/nginx/html

# 複製 nginx 配置
COPY frontend/nginx.conf /etc/nginx/conf.d/default.conf

# 暴露端口
EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
