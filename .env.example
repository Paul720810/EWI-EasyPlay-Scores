# API 設定
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# 安全設定
SECRET_KEY=ewi-easyplay-scores-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,https://ewi.paul720810.dpdns.org

# 檔案路徑
TEMP_DIR=./temp
OUTPUT_DIR=./output
STATIC_DIR=./static

# YouTube 設定
YOUTUBE_DL_FORMAT=bestaudio/best

# Spotify 設定 (免費申請，無需付費)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=https://ewi.paul720810.dpdns.org/api/spotify/callback

# 處理設定
MAX_AUDIO_LENGTH=600
DEMUCS_MODEL=htdemucs
BASIC_PITCH_ONSET_THRESHOLD=0.5
BASIC_PITCH_FRAME_THRESHOLD=0.3

# 錄製設定
MAX_RECORDING_DURATION=180
AUTO_DELETE_HOURS=24
DAILY_RECORDING_LIMIT=10

# 檔案大小限制
MAX_FILE_SIZE=104857600

# Redis 設定
REDIS_URL=redis://localhost:6379

# 資料庫設定
DATABASE_URL=sqlite:///./ewi_scores.db

# 監控設定
ENABLE_METRICS=True
METRICS_PORT=9090

# 日誌設定
LOG_LEVEL=INFO
LOG_FORMAT=json

# 外部 API 金鑰 (可選，用於增強功能)
GROQ_API_KEY=your_groq_api_key_here
NVIDIA_API_KEY=your_nvidia_api_key_here
GOOGLE_API_KEY=your_google_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# GitHub 設定 (用於自動化部署)
GITHUB_TOKEN=your_github_token_here

# Cloudflare 設定 (用於 CDN 和 Pages)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Kaggle 設定 (用於 GPU 處理)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# OCI 設定 (雲端伺服器)
OCI_PUBLIC_IP=140.245.126.35
OCI_PRIVATE_IP=10.0.1.235
OCI_USERNAME=opc

# 網域設定 (使用子網域避免衝突)
DOMAIN_NAME=ewi.paul720810.dpdns.org