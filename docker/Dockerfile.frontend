FROM node:18-alpine as builder

WORKDIR /app

# 複製 package files
COPY frontend/package*.json ./
RUN npm ci

# 複製源代碼並建置
COPY frontend/ .
RUN npm run build

# 生產階段
FROM nginx:alpine

# 複製建置結果
COPY --from=builder /app/dist /usr/share/nginx/html

# 複製 nginx 配置
COPY docker/nginx.conf /etc/nginx/nginx.conf

# 暴露端口
EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
